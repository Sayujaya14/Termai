# Primary LLM API (OpenAI-compatible endpoint)
OPENAI_API_KEY=your-api-key
OPENAI_BASE_URL=https://api.openai.com/v1

# Model names (used when a user has not set their own API settings)
TERMAI_MODEL=openai/gpt-5.1
TERMAI_FALLBACK_MODEL=openai/gpt-4o-mini
# Max tokens per API response (OpenRouter reserves credits by this limit; default 4096)
TERMAI_MAX_OUTPUT_TOKENS=4096

# Optional fallback LLM API when primary fails or is not configured
# OPENROUTER_API_KEY=sk-or-v1-your-key
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Google sign-in (web UI) — create OAuth credentials in Google Cloud Console
# Under "Authorized redirect URIs" add EXACTLY (no trailing slash):
#   http://localhost:8501
# Open the app at that URL (not 127.0.0.1 or a LAN IP) unless you add those too.
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8501
TERMAI_OAUTH_DYNAMIC_REDIRECT=false
# TERMAI_GOOGLE_ALLOWED_DOMAINS=yourcompany.com
# TERMAI_NGROK_URL=https://your-subdomain.ngrok-free.app
# TERMAI_OAUTH_DYNAMIC_REDIRECT=true

# Optional — conversation memory limits
# TERMAI_CONVERSATION_MAX_TURNS=15
# TERMAI_CONVERSATION_MAX_CHARS=24000
